# ─────────────────────────────────────────────────────────────
# PicturePerfectTones — Local Development Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.
# NEVER commit your actual .env to git.

# ── WordPress (Hostinger) ─────────────────────────────────────
# Your WordPress site URL (no trailing slash)
VITE_WP_URL=https://magenta-hornet-709629.hostingersite.com
WP_URL=https://magenta-hornet-709629.hostingersite.com

# Shared secret between this app and your WordPress snippet
# Must match the PPT_API_SECRET value set in your WordPress snippet
PPT_API_SECRET=ppt-secret-abc123xyz

# ── Razorpay ──────────────────────────────────────────────────
# Public key — safe to expose in frontend (VITE_ prefix required)
VITE_RAZORPAY_KEY_ID=rzp_test_SdUUaHOqwlqdYm

# Server-side only — never expose these in the browser
RAZORPAY_KEY_ID=rzp_test_SdUUaHOqwlqdYm
RAZORPAY_KEY_SECRET=lYlgNF6Cp8wV5pjHZYd5hA0E
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret-here

# ── Admin Panel ───────────────────────────────────────────────
# Login credentials for the /admin page
ADMIN_EMAIL=ppt@gmail.com
ADMIN_PASSWORD=123

# ── Server Port (optional) ────────────────────────────────────
# Default is 5000 if not set
# PORT=5000
